# TRACE24 local env (copy to .env.local — never commit secrets)

# Open D (optional; endpoint often 404)
OPEND_API_KEY=

# BOT public API (optional)
BOT_API_TOKEN=

# LLM assist — OpenAI-compatible chat completions
# Improves RAG answers, signal review, rule drafts. Does NOT set risk scores.
LLM_API_KEY=
# or: OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# LLM_ENABLED=true
# LLM_TIMEOUT_MS=45000
