# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large uncompressed catalog (commit agencies.json.gz only)
/data/catalog/agencies.json

# contracts cache: commit .json.gz + sync manifest; ignore other uncompressed dumps
/data/contracts-cache/*.json
!/data/contracts-cache/*.json.gz
!/data/contracts-cache/agencies-to-sync.json
!/data/contracts-cache/sync-last-run.json
